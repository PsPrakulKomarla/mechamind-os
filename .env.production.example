# =============================================================================
# Mechamind OS - Production Environment Configuration
# =============================================================================
# Copy this to .env.production and fill in your values
# Never commit this file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=Mechamind OS
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# DATABASE (Production PostgreSQL - e.g., AWS RDS, Azure Database, Supabase)
# -----------------------------------------------------------------------------
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@prod-db-host:5432/meachamind
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DB_ECHO=false

# -----------------------------------------------------------------------------
# SUPABASE (Production)
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-production-anon-key
SUPABASE_SERVICE_KEY=your-production-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# -----------------------------------------------------------------------------
# VECTOR DATABASE (Qdrant Cloud or Self-hosted)
# -----------------------------------------------------------------------------
QDRANT_URL=https://your-qdrant-cloud-url:6333
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=industrial_documents

# -----------------------------------------------------------------------------
# GRAPH DATABASE (Neo4j Aura or Self-hosted)
# -----------------------------------------------------------------------------
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# -----------------------------------------------------------------------------
# REDIS (Production - e.g., AWS ElastiCache, Azure Cache for Redis)
# -----------------------------------------------------------------------------
REDIS_URL=rediss://username:password@redis-host:6379/0
CELERY_BROKER_URL=rediss://username:password@redis-host:6379/0
CELERY_RESULT_BACKEND=rediss://username:password@redis-host:6379/0

# -----------------------------------------------------------------------------
# LLM PROVIDERS (At least one required)
# -----------------------------------------------------------------------------

# OpenAI (Production)
OPENAI_API_KEY=sk-prod-xxx
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic (Production)
ANTHROPIC_API_KEY=sk-ant-prod-xxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (Self-hosted, optional)
# OLLAMA_BASE_URL=http://ollama-host:11434
# OLLAMA_MODEL=llama3.1:70b
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Default provider
DEFAULT_LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# DOCUMENT PROCESSING
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=104857600  # 100MB
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOC=500

# Video processing
VIDEO_FRAME_INTERVAL=5
WHISPER_MODEL=base

# OCR
TESSERACT_PATH=/usr/bin/tesseract

# -----------------------------------------------------------------------------
# RAG CONFIGURATION
# -----------------------------------------------------------------------------
TOP_K_RESULTS=10
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_LENGTH=8000
USE_RERANKER=true

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-64-character-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS - Production domains only
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=true

# -----------------------------------------------------------------------------
# UPLOAD DIRECTORY (Production should use S3/GCS)
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_VIDEO_PROCESSING=true
ENABLE_OCR=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_SAFETY_MODULE=true
ENABLE_MAINTENANCE_PREDICTION=true