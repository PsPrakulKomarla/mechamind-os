# =============================================================================
# Mechamind OS - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
APP_NAME=Mechamind OS
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# -----------------------------------------------------------------------------
# DATABASE (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.xxx.supabase.co:5432/postgres

# Connection pool
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DB_ECHO=false

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Supabase Storage bucket for file uploads
SUPABASE_STORAGE_BUCKET=documents

# -----------------------------------------------------------------------------
# VECTOR DATABASE (Qdrant) - Optional for MVP, pgvector works
# -----------------------------------------------------------------------------
# Local: http://localhost:6333
# Cloud: https://xxx.us-east-1-0.aws.cloud.qdrant.io:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=industrial_documents

# -----------------------------------------------------------------------------
# GRAPH DATABASE (Neo4j) - Optional for MVP
# -----------------------------------------------------------------------------
# Local: bolt://localhost:7687
# Aura: neo4j+s://xxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# -----------------------------------------------------------------------------
# REDIS (Celery broker, caching, rate limiting)
# -----------------------------------------------------------------------------
# Local: redis://localhost:6379/0
# Cloud: rediss://username:password@host:port/0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LLM PROVIDERS (At least one required)
# -----------------------------------------------------------------------------

# OpenAI (GPT-4o, embeddings)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Anthropic (Claude 3.5 Sonnet)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Ollama (Local LLMs - no API key needed)
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull models: ollama pull llama3.1:70b && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Default provider: openai | anthropic | ollama
DEFAULT_LLM_PROVIDER=openai

# -----------------------------------------------------------------------------
# DOCUMENT PROCESSING
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=104857600  # 100MB in bytes
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOC=500

# Video processing
VIDEO_FRAME_INTERVAL=5  # seconds between frames
WHISPER_MODEL=base  # tiny, base, small, medium, large

# OCR
TESSERACT_PATH=/usr/bin/tesseract  # Linux/Mac
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe  # Windows

# -----------------------------------------------------------------------------
# RAG CONFIGURATION
# -----------------------------------------------------------------------------
TOP_K_RESULTS=10
SIMILARITY_THRESHOLD=0.7
MAX_CONTEXT_LENGTH=8000
USE_RERANKER=true

# -----------------------------------------------------------------------------
# AUTHENTICATION & SECURITY
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
PROMETHEUS_ENABLED=true

# -----------------------------------------------------------------------------
# UPLOAD DIRECTORY (for local file storage fallback)
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
ENABLE_VIDEO_PROCESSING=true
ENABLE_OCR=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_SAFETY_MODULE=true
ENABLE_MAINTENANCE_PREDICTION=true